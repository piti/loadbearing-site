---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { KIT_SLUG, KIT_PDF_PATH, KIT_BUILDER_PATH } from '../../../consts';

// One static page at the fixed slug. Hidden, noindex, unlinked (spec §4).
export function getStaticPaths() {
  return [{ params: { slug: KIT_SLUG } }];
}
---
<BaseLayout
  title="The Load-Bearing Library"
  description="Every kit, template, and structure I've released — free to take and adapt."
  noindex={true}
>
  <div class="eyebrow"><span class="dot"></span>Load-Bearing<span class="sep">·</span>Library</div>
  <h1 class="page-title">The Library</h1>
  <p class="lede">
    Everything I've released — the structures, templates, and kits underneath the systems I write
    about. Free to take and adapt. <b>New ones land here</b> as they ship.
  </p>

  <section class="lib">
    <article class="res">
      <div class="res-meta">PDF guide + Markdown builder</div>
      <h2>The Context Vault</h2>
      <p>
        Give your AI a memory that's actually yours — a folder of plain files you own, not a product
        you rent. The three-layer folder structure, the anchor template, the <span class="mono">AGENTS.md</span>
        entry file every agent reads first, and the prompts that load context.
      </p>
      <p class="sub">
        New: the <b>builder</b> — a Markdown file you hand to your AI. It interviews you and builds the
        vault with you, filled in for your actual projects. Download it, upload it to your assistant,
        and say “run this.”
      </p>
      <div class="btn-row">
        <a class="btn" href={KIT_PDF_PATH}>Download the guide (PDF) &rarr;</a>
        <a class="btn alt" href={KIT_BUILDER_PATH}>Get the builder &rarr;</a>
      </div>
    </article>
  </section>

  <p class="lib-foot">
    <b>Load-Bearing</b> is a newsletter about building real AI systems from first principles. If a
    friend sent you here, the kit + newsletter are free — <a href="/subscribe">grab them</a> and you'll
    get a heads-up whenever something new lands in the library.
  </p>
</BaseLayout>

<style>
  .lib { display: grid; gap: 18px; }
  .res {
    position: relative; background: var(--bg-panel); border: 1px solid var(--line);
    border-radius: 14px; padding: 24px 24px 22px 28px; transition: border-color .15s;
  }
  .res:hover { border-color: var(--signal); }
  .res::before {
    content: ""; position: absolute; left: 0; top: 18px; bottom: 18px; width: 3px;
    border-radius: 3px; background: linear-gradient(180deg, var(--signal), var(--signal-deep));
  }
  .res-meta {
    font-family: var(--mono); font-size: 11.5px; letter-spacing: .18em; text-transform: uppercase;
    color: var(--text-faint); margin-bottom: 10px;
  }
  .res h2 {
    font-family: var(--display); font-weight: 600; font-size: clamp(20px,3vw,25px);
    margin: 0 0 8px; letter-spacing: -.02em; color: var(--heading);
  }
  .res p { color: var(--text-soft); font-size: 15.5px; margin: 0 0 16px; max-width: 56ch; }
  .res p .mono { font-family: var(--mono); font-size: .9em; }
  .res .sub { color: var(--text-faint); font-size: 14px; margin: -4px 0 16px; }
  .res .sub b { color: var(--text-soft); font-weight: 600; }
  .lib-foot {
    margin-top: 40px; padding-top: 24px; border-top: 1px solid var(--line);
    font-size: 14px; color: var(--text-faint); max-width: 60ch;
  }
  .lib-foot b { color: var(--text); font-weight: 600; }
</style>
