---
import BaseLayout from '../layouts/BaseLayout.astro';
import SubscribeCTA from '../components/SubscribeCTA.astro';
---
<BaseLayout
  title="About"
  description="An engineer with 20+ years in platform security and systems architecture, writing about building with AI from first principles."
>
  <div class="eyebrow"><span class="dot"></span>Load-Bearing<span class="sep">·</span>About</div>
  <h1 class="page-title">About</h1>
  <div class="prose">
    <p>
      I'm Peter — an engineer with 20+ years in platform security and systems architecture,
      including co-founding an open-source hardware root of trust. Load-Bearing is my notebook
      for building with AI the way I'd build anything that has to last: from first principles,
      owned in plain files, made to survive the tool that made it. Everything here is something
      I actually use. I share the structure, not a pitch.
    </p>
    <!-- (Peter: add surname + any links you want on this page.) -->
  </div>

  <SubscribeCTA />
</BaseLayout>
