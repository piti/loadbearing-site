---
// The strata motif — layered horizontal bands with the amber top line.
// Copied verbatim from the locked landing files so the brand reads as one.
---
<svg class="strata" aria-hidden="true" viewBox="0 0 1440 240" preserveAspectRatio="none">
  <defs><linearGradient id="l1" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0" stop-color="#243042"/><stop offset="1" stop-color="#161d27"/>
  </linearGradient></defs>
  <rect x="0" y="2" width="1440" height="3" fill="#d68c10"/>
  <rect x="430" y="2" width="580" height="3" fill="#ffd98a"/>
  <rect x="0" y="14" width="1440" height="226" fill="url(#l1)"/>
  <g stroke="#ffffff" stroke-opacity="0.04">
    <line x1="0" y1="52" x2="1440" y2="52"/><line x1="0" y1="92" x2="1440" y2="92"/>
    <line x1="0" y1="140" x2="1440" y2="140"/><line x1="0" y1="196" x2="1440" y2="196"/>
  </g>
  <g stroke="#d68c10" stroke-opacity="0.10">
    <line x1="0" y1="118" x2="1440" y2="118"/><line x1="0" y1="172" x2="1440" y2="172"/>
  </g>
</svg>
