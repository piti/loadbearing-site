---
import { NAV, SITE_TITLE } from '../consts';
const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
---
<header class="site-header">
  <a class="brand" href="/" aria-label={`${SITE_TITLE} — home`}>
    <!-- LB lettermark (signal). Tight-crop viewBox per IDENTITY.md. -->
    <svg class="mark" viewBox="520 470 1010 1110" aria-hidden="true" fill="#2E6BF0">
      <path d="M 1028.45 498.446 C 1084.2 497.828 1140.72 498.414 1196.53 498.3 C 1278.67 498.133 1356.28 530.777 1413.7 589.951 C 1469.78 647.229 1500.85 724.412 1500.1 804.568 C 1498.76 891.444 1465.93 961.363 1404.02 1021.43 C 1429.18 1047.28 1450.56 1069.93 1466.42 1102.77 C 1563.8 1304.39 1440.52 1507.94 1231.02 1547.75 L 1231.03 1526.97 C 1231.05 1472.89 1232.1 1415.42 1230.75 1361.67 C 1252.15 1352.93 1268.52 1343.86 1285.52 1327.09 C 1355.21 1258.92 1323.57 1144.01 1236.26 1109.4 C 1203.17 1096.29 1152.72 1099.58 1116.55 1099.65 L 1028.55 1099.78 C 1027.35 1042.56 1028.32 982.221 1028.45 924.764 L 1138.14 924.914 C 1162.64 924.926 1204.32 926.427 1226.62 920.737 C 1246.82 915.492 1265.32 905.091 1280.29 890.554 C 1305.7 866.654 1320.4 833.517 1321.06 798.639 C 1321.78 767.367 1309.88 737.12 1288.05 714.72 C 1246.37 672.683 1188.98 678.945 1134.8 678.924 L 1028.43 678.694 C 1027.08 621.066 1028.41 556.543 1028.45 498.446 z"/>
      <path d="M 548.561 498.19 L 726.081 497.993 L 727.076 1376.21 C 775.649 1377.69 833.588 1376.05 882.767 1376.01 L 1170.14 1375.8 L 1170.28 1553.19 L 548.539 1553.13 L 548.561 498.19 z"/>
      <path d="M 791.646 498.093 L 965.765 498.019 C 966.575 555.15 965.241 613.287 965.184 670.5 L 965.549 1152.58 C 988.698 1153.66 1016.59 1153.04 1040.09 1153.04 L 1170.06 1152.98 L 1170.08 1318.85 L 791.434 1318.41 C 790.667 1248.86 791.611 1177.54 791.673 1107.84 L 791.779 661.742 C 792.128 607.193 792.083 552.642 791.646 498.093 z"/>
    </svg>
    <span class="name">Load<span class="hy">‑</span>Bearing</span>
  </a>
  <div class="nav-wrap">
    <nav class="nav" aria-label="Primary">
      {NAV.map((item) => (
        <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>
    <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Switch to light mode">
      <!-- sun shown on dark surface (action: go light) -->
      <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
      </svg>
      <!-- moon shown on light surface (action: go dark) -->
      <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </button>
  </div>
</header>
<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    function syncLabel() {
      var isDark = document.documentElement.classList.contains('dark');
      btn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
    }
    syncLabel();
    btn.addEventListener('click', function () {
      var root = document.documentElement;
      var toLight = root.classList.contains('dark');
      root.classList.toggle('dark', !toLight);
      root.classList.toggle('light', toLight);
      try { localStorage.setItem('theme', toLight ? 'light' : 'dark'); } catch (e) {}
      syncLabel();
    });
  })();
</script>
