---
// Generic brand-level CTA (spec section 6). No edition-specific copy. Subscribe -> /subscribe.
// No kit/library/PDF links leak onto public pages.
interface Props { heading?: string; body?: string; }
const {
  heading = `Subscribe to Load-Bearing`,
  body = `An engineer’s notebook on building with AI. Subscribe and I’ll send you The Context Vault — the file-based memory kit I actually use — as a welcome gift.`,
} = Astro.props;
---
<section class="cta">
  <h2>{heading}</h2>
  <p>{body}</p>
  <div class="btn-row">
    <a class="btn" href="/subscribe">Subscribe &rarr;</a>
  </div>
</section>
