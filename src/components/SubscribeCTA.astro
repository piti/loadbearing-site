---
// The only reward CTA anywhere public (spec §4/§5): Subscribe → /subscribe.
// No kit/library/PDF links leak onto public pages.
interface Props { heading?: string; body?: string; }
const {
  heading = 'Get the kit, then the newsletter',
  body = 'Every edition ships with a free kit — the actual structure or tool it describes, yours to copy. Subscribe and I’ll email you the current one.',
} = Astro.props;
---
<section class="cta">
  <h2>{heading}</h2>
  <p>{body}</p>
  <div class="btn-row">
    <a class="btn" href="/subscribe">Subscribe &rarr;</a>
  </div>
</section>
