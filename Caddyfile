# Serve the static Astro build. Coolify terminates TLS at its proxy and forwards
# plain HTTP to this container on :80, so we listen on :80 (no TLS here).
:80 {
	root * /usr/share/caddy
	encode gzip zstd
	# Astro's sitemap integration emits sitemap-index.xml; expose /sitemap.xml too.
	rewrite /sitemap.xml /sitemap-index.xml
	# Astro builds directory-style URLs (/blog/the-foundation/index.html),
	# so try_files resolves clean URLs and the SPA-less fallthrough is a 404 page.
	try_files {path} {path}/ {path}.html
	file_server
	handle_errors {
		@404 expression {http.error.status_code} == 404
		rewrite @404 /404.html
		file_server
	}
	header {
		-Server
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}
}
